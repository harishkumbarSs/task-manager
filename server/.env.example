PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/task-manager
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Access JWT lifetime (default 15m). Examples: 15m, 1h, 7d
# JWT_EXPIRES_IN=15m
# Refresh token storage lifetime in days (default 7)
# REFRESH_TOKEN_DAYS=7
CLIENT_ORIGIN=http://localhost:5173

# Optional: rate limits (requests per window)
# RATE_LIMIT_MAX=400
# AUTH_RATE_LIMIT_MAX=25
