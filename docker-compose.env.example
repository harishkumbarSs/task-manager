# Copy this file to `.env` in the same folder as `docker-compose.yml`
# (the repo root). Docker Compose reads it for ${JWT_SECRET} substitution.
#
#   Windows (PowerShell):  Copy-Item docker-compose.env.example .env
#   Git Bash / macOS:      cp docker-compose.env.example .env
#
# Then edit `.env` and use a long random value (do not commit `.env`).

JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
